{
  "name": "shipmind-backend",
  "version": "2.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/orchestration.worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/orchestration.worker.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@prisma/client": "^5.7.1",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "@anthropic-ai/sdk": "^0.10.0",
    "axios": "^1.6.2",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.1",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "nodemailer": "^6.9.8",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/resources": "^1.21.0",
    "@opentelemetry/semantic-conventions": "^1.21.0",
    "@opentelemetry/sdk-trace-base": "^1.21.0",
    "@opentelemetry/instrumentation-http": "^0.48.0",
    "@opentelemetry/instrumentation-express": "^0.38.0",
    "@opentelemetry/instrumentation-ioredis": "^0.38.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/nodemailer": "^6.4.14",
    "tsx": "^4.7.0",
    "prisma": "^5.7.1"
  }
