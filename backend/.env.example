# ═══════════════════════════════════════════════════════════════════════════════
#  ShipMind Backend — Environment Variables
#  Copy this to .env and fill in your values before running.
#
#  Usage: cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://shipmind:shipmind_secure@localhost:5432/shipmind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Maps ───────────────────────────────────────────────────────────────
# Enable "Maps JavaScript API" and "Directions API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=AIzaSy_your_key_here

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3001/api/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── JWT & Encryption ──────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=shipmind-dev-secret-CHANGE-IN-PRODUCTION-min-32-chars
ENCRYPTION_KEY=shipmind-enc-key-32bytes-CHANGE-ME

# ── Email (MFA OTP) ───────────────────────────────────────────────────────────
# For hackathon/dev: leave blank — OTP will be logged to console
# For production: use Resend (smtp.resend.com) or any SMTP provider
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shipmind.ai

# ── App Config ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
SERVICE_NAME=shipmind-backend

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── Worker Config ─────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
